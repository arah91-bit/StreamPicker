# Non-PIA settings for deploy/rqbit-pia.compose.yml.
#
# Keep this file mode 0600 after filling it in. VPN_USER and VPN_PASS are
# intentionally absent: load the same protected env file already used by
# qBittorrent before this file (see PRIVATE_TRACKERS.md).

# The NAS address reachable from the Stream Picker host.
RQBIT_BIND_IP=192.168.1.10

# Existing NAS-local directory used by the long-term qBittorrent instance.
PRIVATE_DOWNLOAD_HOST_PATH=/volume1/path/to/nuviodownloads

# Match ownership of the existing qBittorrent download directory.
PUID=1000
PGID=1000
TZ=America/New_York
PIA_SERVER_REGIONS=US New York

# Generate independent service credentials; do not reuse the PIA password.
RQBIT_HTTP_USER=stream-picker
RQBIT_HTTP_PASSWORD=replace-with-a-long-random-value
RQBIT_VPN_CONTROL_API_KEY=replace-with-output-of-gluetun-genkey
