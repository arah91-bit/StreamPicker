# ── stream-picker · environment seed ────────────────────────────────────────
# Copy this file to .env and fill it in:   cp .env.example .env
#
# ADDON_SECRET plus the Compose-mounted encryption key created in README's
# quick start are required to boot. On the first local dashboard visit, choose
# a separate administrator username and password.
# Everything below it can be left alone
# and configured later from the Settings dashboard at
#   http://<host>:8011/settings        (LAN-only, no secret in the URL)
# (the dashboard writes to data/config.json and each service has a live Test
# button). Anything you do set here is used as the starting value.
#
# This file lists just the essentials. For the COMPLETE menu of every setting
# the addon understands — with defaults and one-line descriptions — see
# .env.reference in the repo (handy when configuring by hand or with an AI):
#   https://github.com/arah91-bit/StreamPicker/blob/main/.env.reference

# REQUIRED — the unguessable path segment gating addon installation.
# Generate: openssl rand -hex 24
ADDON_SECRET=

# Optional unattended/preseeded dashboard login. Leave ADMIN_PASSWORD unset to
# use the safer first-run account-creation screen (recommended).
#ADMIN_USERNAME=admin
#ADMIN_PASSWORD=

# Path *inside the container* to the 32-byte key used for encrypting dashboard
# secrets. Production Compose should mount a host file here read-only; keep the
# host key outside this repository, mode 0600, and back it up separately.
#CONFIG_ENCRYPTION_KEY_FILE=/run/secrets/stream_picker_config_key

# Immediate peers allowed to supply X-Forwarded-For. Add the exact IP/CIDR of
# your reverse proxy if needed; never use 0.0.0.0/0. Direct LAN access needs no
# entry because it does not use a forwarding header.
#TRUSTED_PROXIES=127.0.0.0/8,::1/128

# Where players reach this addon from OUTSIDE the container. It's baked into the
# playback URLs the player fetches, so it must be reachable from your devices:
#   • quick LAN test:   http://192.168.x.x:8011   (your host's LAN IP)
#   • real setup:       https://autostream.example.com  (your reverse-proxy domain)
ADDON_PUBLIC_URL=http://localhost:8011

# Name shown in your player's addon list (optional).
#ADDON_NAME=Auto Stream

# Container timezone (affects log/dashboard timestamps only).
#TZ=America/New_York

# ── optional pre-seeds — most people set these in the dashboard instead ──────
# Uncomment to bake a value in from the start rather than typing it in the UI.
#FAST_BASE_URL=                 # Comet manifest base (the URL embeds debrid keys)
#STREMTHRU_BASE_URL=            # StremThru Torz manifest base
#MEDIAFUSION_BASE_URL=          # MediaFusion manifest base
#TMDB_API_KEY=                  # titles, original language, release dates
#OMDB_API_KEY=                  # cached title/year/type/runtime corroboration
#OMDB_DAILY_BUDGET=750          # hard UTC-day cap (plan allows 1,000)
#TVDB_API_KEY=                  # season-rollover fallback for episode prefetch
# Native Jellyfin library (Jellio is not required). URL is the internal/API
# address reachable from this container. Prefer entering the password in the
# dashboard so it is AES-256-GCM encrypted in config.json; .env is plaintext.
#JELLYFIN_URL=http://jellyfin:8096
#JELLYFIN_USERNAME=
#JELLYFIN_PASSWORD=             # supported seed; dashboard entry is safer
#NZB_INDEXERS=name|https://indexer.example/api|APIKEY;name2|https://.../api|APIKEY2
#NZBDAV_URL=                    # nzbdav base URL
#NZBDAV_USER=
#NZBDAV_PASS=
#JELLYSEERR_URL=                # preferred path for requesting missing titles
#JELLYSEERR_API_KEY=
#RADARR_URL=                    # direct movie fallback
#RADARR_API_KEY=
#SONARR_URL=                    # direct series fallback
#SONARR_API_KEY=
